{
  "name": "agentboard-e2e-cypress",
  "version": "1.0.0",
  "private": true,
  "description": "Cypress E2E and Component tests for AgentBoard",
  "scripts": {
    "test": "cypress run",
    "test:local": "cross-env ENVIRONMENT=e2e TEST_TAGS=@local cypress run --spec cypress/e2e/auth/login.cy.ts,cypress/e2e/auth/register.cy.ts,cypress/e2e/auth/session.cy.ts",
    "test:staging": "cross-env ENVIRONMENT=staging TEST_TAGS=@staging cypress run",
    "test:open": "cypress open",
    "test:e2e": "cypress run --e2e",
    "test:component": "cypress run --component",
    "lint": "eslint cypress --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.0",
    "@testing-library/cypress": "^10.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cross-env": "^7.0.3",
    "cypress": "^13.0.0",
    "cypress-mochawesome-reporter": "^3.8.2",
    "dotenv": "^17.4.2",
    "eslint": "^8.0.0",
    "eslint-plugin-cypress": "^2.15.0",
    "typescript": "^5.4.0"
  }
}
